generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// === EXISTING MODELS (unchanged except for new relations) ===

model documents {
  id                BigInt    @id @default(autoincrement())
  loan_id           BigInt
  doc_type          String
  file_name         String?
  file_url          String?
  status            String?   @default("NEEDED")
  xai_feedback      String?
  underwriter_notes String?
  ae_comments       Json?     @default("[]")
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  loans             loans     @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loan_id], map: "idx_documents_loan")
  @@index([doc_type], map: "idx_documents_type")
}

model loan_applications {
  id                  String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id             String
  status              String?        @default("draft")
  form_data           Json?
  borrowers           Json?
  selected_product_id BigInt?
  pricing_result      Json?
  created_at          DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?      @default(now()) @db.Timestamptz(6)
  organization_id     String?
  organizations       organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([organization_id], map: "idx_loan_applications_org")
  @@index([status], map: "idx_loan_applications_status")
  @@index([user_id], map: "idx_loan_applications_user_id")
}

model loan_documents {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  loan_id       BigInt?
  file_name     String
  file_url      String
  document_type String?   @default("unlabeled")
  uploaded_via  String?   @default("email")
  uploaded_at   DateTime? @default(now()) @db.Timestamp(6)
  loans         loans?    @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model loan_email_logs {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  loan_id          BigInt?
  from_email       String?
  subject          String?
  analysis_summary String?
  processed_at     DateTime? @default(now()) @db.Timestamp(6)
  loans            loans?    @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model loan_products {
  id                     String         @id @default(dbgenerated("('prod_'::text || substr(md5((random())::text), 1, 8))"))
  name                   String
  description            String?
  guidelines_url         String?
  created_at             DateTime?      @default(now()) @db.Timestamptz(6)
  pricing_matrix         Json?          
  active                 Boolean?       @default(true)
  organization_id        String?
  default_profit_percent Decimal?       @default(1.0) @db.Decimal
  organizations          organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([active], map: "idx_loan_products_active")
  @@index([organization_id], map: "idx_loan_products_org")
}

model loans {
  id               BigInt            @id @default(autoincrement())
  product_id       String?
  originator_id    String
  borrower_name    String?
  property_address String
  loan_amount      Decimal?          @db.Decimal(12, 2)
  loan_type        String?           @default("purchase")
  status           String?           @default("PENDING")
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?         @default(now()) @db.Timestamptz(6)
  loan_status      String?           @default("Processing")
  notes            String?
  purpose          String?
  property_type    String?
  amortization     String?

  processor_id     String?
  underwriter_id   String?
  organization_id  String?

  documents        documents[]
  loan_documents   loan_documents[]
  loan_email_logs  loan_email_logs[]

  @@index([originator_id], map: "idx_loans_originator")
  @@index([product_id], map: "idx_loans_product")
  @@index([organization_id])
}

model organizations {
  id                String              @id @default(dbgenerated("('org_'::text || substr(md5((random())::text), 1, 12))"))
  name              String
  slug              String              @unique
  logo_url          String?
  primary_color     String?             @default("#000000")
  domain            String?             @unique
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  active            Boolean?            @default(true)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  clerk_org_id      String?             @unique

  // === Markup Fields (we'll use the new table going forward) ===
  wholesale_markup  Decimal?            @default(0) @db.Decimal(5, 2)
  retail_markup     Decimal?            @default(0) @db.Decimal(5, 2)

  loan_applications loan_applications[]
  loan_products     loan_products[]
  markups           pricing_markups[]     // ← NEW
}

model pending_organizations {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_name         String
  contact_name         String?
  email                String    @unique
  phone                String?
  website              String?
  loan_volume_estimate String?
  notes                String?
  status               String?   @default("pending")
  reviewed_by          String?   @db.Uuid
  reviewed_at          DateTime? @db.Timestamptz(6)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
}

model profiles {
  id         String    @id
  role       String?   @default("user")
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model users {
  id                  String    @id
  email               String?
  full_name           String?
  role                String?   @default("BROKER_AE")
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)
  parent_id           String?
  organization_id     String?

  // === NEW BROKER WHITE-LABEL FIELDS ===
  broker_company_name String?
  broker_logo_url     String?
  broker_custom_url   String?

  users               users?    @relation("usersTousers", fields: [parent_id], references: [id])
  other_users         users[]   @relation("usersTousers")
  brokerMarkups       pricing_markups[] @relation("BrokerMarkups")

  @@index([role])
}

// ==================== NEW MODELS ====================

model pricing_markups {
  id                String   @id @default(cuid())
  organization_id   String
  broker_id         String?           // null = organization-wide default
  markup_type       String   // 'wholesale', 'retail', 'broker_retail'
  value             Decimal  @db.Decimal(5, 3)  // e.g. 1.25
  description       String?
  active            Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @updatedAt         @db.Timestamptz(6)

  organization      organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  broker            users?        @relation("BrokerMarkups", fields: [broker_id], references: [id])

  @@index([organization_id, broker_id, markup_type])
  @@index([markup_type])
}

// ==================== ENUM ====================
enum Role {
  SUPER_ADMIN
  ADMIN
  TECH_SUPPORT 
  ORG_ADMIN
  LOAN_UNDERWRITER
  LOAN_PROCESSOR
  SENIOR_ACCOUNT_EXECUTIVE
  ACCOUNT_EXECUTIVE
  SENIOR_BROKER
  JUNIOR_BROKER
  LENDING_SUPERVISOR
  BROKER
  BROKER_AE
  BORROWER
}
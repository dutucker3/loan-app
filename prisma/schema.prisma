generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations.
model documents {
  id                BigInt    @id @default(autoincrement())
  loan_id           BigInt
  doc_type          String
  file_name         String?
  file_url          String?
  status            String?   @default("NEEDED")
  xai_feedback      String?
  underwriter_notes String?
  ae_comments       Json?     @default("[]")
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@index([doc_type])
  @@index([loan_id])
}

model loan_applications {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id             String
  status              String?   @default("draft")
  form_data           Json?
  borrowers           Json?
  selected_product_id BigInt?
  pricing_result      Json?
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)
  organization_id     String?

  @@index([organization_id])
  @@index([status])
  @@index([user_id])
}

model loan_documents {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  loan_id       BigInt?
  file_name     String
  file_url      String
  document_type String?   @default("unlabeled")
  uploaded_via  String?   @default("email")
  uploaded_at   DateTime? @default(now()) @db.Timestamp(6)
}

model loan_email_logs {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  loan_id          BigInt?
  from_email       String?
  subject          String?
  analysis_summary String?
  processed_at     DateTime? @default(now()) @db.Timestamp(6)
}

model loan_products {
  id                     String    @id @default(dbgenerated("('prod_'::text || substr(md5((random())::text), 1, 8))"))
  name                   String
  description            String?
  guidelines_url         String?
  created_at             DateTime? @default(now()) @db.Timestamptz(6)
  pricing_matrix         Json?     @default("{\"series\": {\"standard\": {\"maxLTV\": 75, \"baseAdjustment\": 0}, \"signature\": {\"maxLTV\": 80, \"baseAdjustment\": -0.25}, \"streamline\": {\"maxLTV\": 80, \"baseAdjustment\": -0.5}}, \"baseRate\": 9.0, \"dscrMaxLtv\": {}, \"ltvAdjustments\": {\"60\": 0, \"65\": -0.125, \"70\": -0.375, \"75\": -0.75, \"80\": -1.25}, \"dscrAdjustments\": {\"1.25+\": 0, \"0.75-0.99\": -0.75, \"1.00-1.14\": -0.375, \"1.15-1.24\": -0.125}, \"ficoAdjustments\": {\"780+\": 0, \"660-679\": -2.0, \"680-699\": -1.25, \"700-719\": -0.75, \"720-739\": -0.375, \"740-759\": -0.25, \"760-779\": -0.125}}")
  active                 Boolean?  @default(true)
  organization_id        String?
  default_profit_percent Decimal?  @default(1.0) @db.Decimal
  standard_conditions    Json?     @default("{\"purchase\": [], \"refinance\": []}")
  retail_borrower_margin Decimal?  @default(0) @db.Decimal(5, 2)
  owner_user_id          String?
  insurance_requirements String?
  bridge_config          Json?
  mortgagee_clause       String?

  @@index([organization_id], map: "idx_loan_products_org")
  @@index([owner_user_id], map: "idx_loan_products_owner")
  @@index([active])
  @@index([organization_id])
}

model loans {
  id                 BigInt    @id @default(autoincrement())
  product_id         String?
  originator_id      String
  borrower_name      String?
  property_address   String
  loan_amount        Decimal?  @db.Decimal(12, 2)
  loan_type          String?   @default("purchase")
  status             String?   @default("PENDING")
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  updated_at         DateTime? @default(now()) @db.Timestamptz(6)
  loan_status        String?   @default("Processing")
  notes              String?
  purpose            String?
  property_type      String?
  amortization       String?
  processor_id       String?
  underwriter_id     String?
  organization_id    String?
  reggora_loan_id    String?
  reggora_order_id   String?
  reggora_status     String?
  reggora_fee_actual Decimal?  @db.Decimal(10, 2)
  insurance_company  Json?
  mortgagee_clause   String?
  title_company      Json?

  @@index([organization_id])
  @@index([originator_id])
  @@index([product_id])
  @@index([insurance_company], map: "idx_loans_insurance_company", type: Gin)
  @@index([reggora_loan_id], map: "idx_loans_reggora_loan_id")
  @@index([reggora_order_id], map: "idx_loans_reggora_order_id")
  @@index([title_company], map: "idx_loans_title_company", type: Gin)
}

model organizations {
  id                                   String    @id @default(dbgenerated("('org_'::text || substr(md5((random())::text), 1, 12))"))
  name                                 String
  slug                                 String    @unique
  logo_url                             String?
  primary_color                        String?   @default("#000000")
  domain                               String?   @unique
  created_at                           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at                           DateTime? @default(now()) @db.Timestamptz(6)
  active                               Boolean?  @default(true)
  wholesale_markup                     Decimal?  @default(0) @db.Decimal(5, 2)
  retail_markup                        Decimal?  @default(0) @db.Decimal(5, 2)
  raw_attrs                            Json?     @default("{}")
  approved                             Boolean?  @default(false)
  approved_at                          DateTime? @db.Timestamptz(6)
  approved_by                          String?
  from_email                           String?
  support_email                        String?
  reply_to_email                       String?
  custom_domain_verified               Boolean?  @default(false)
  parent_organization_id               String?
  is_root                              Boolean?  @default(false)
  base_rates                           Json?
  pass_credit_report_costs_to_borrower Boolean?  @default(false)
  credit_report_cost_amount            Decimal?  @db.Decimal(10, 2)
  benchmark_treasury                   String?
  mortgagee_clause                     String?
  referred_by                          String?   @db.Uuid
  hidden                               Boolean?  @default(false)
  appraisal_fee_preset                 Decimal?  @default(900) @db.Decimal(10, 2)

  @@index([domain], map: "idx_organizations_domain")
  @@index([from_email], map: "idx_organizations_from_email")
  @@index([parent_organization_id], map: "idx_organizations_parent")
  @@index([referred_by], map: "idx_organizations_referred_by")
}

model pending_organizations {
  id                     String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_name           String
  contact_name           String?
  email                  String    @unique
  phone                  String?
  website                String?
  loan_volume_estimate   String?
  notes                  String?
  status                 String?   @default("pending")
  reviewed_by            String?   @db.Uuid
  reviewed_at            DateTime? @db.Timestamptz(6)
  created_at             DateTime? @default(now()) @db.Timestamptz(6)
  owners                 Json?
  managers               Json?
  additional_users       Json?
  products_offered       Json?
  submitted_by           String?   @db.Uuid
  address                String?
  city                   String?
  state                  String?
  zip                    String?
  agreement_accepted     Boolean?  @default(false)
  documents              Json?
  parent_organization_id String?   @db.Uuid
  referred_by            String?   @db.Uuid
}

model profiles {
  id              String   @id @db.Uuid
  email           String?
  role            String?  @default("BORROWER")
  full_name       String?
  first_name      String?
  last_name       String?
  image_url       String?
  phone           String?
  organization_id String?
  // parent_id supports AE hierarchy for SENIOR_ACCOUNT_EXECUTIVE / ACCOUNT_EXECUTIVE (Send Broker Invite preserves the inviting AE;
  // dashboard AE-only buttons + wholesale user management; L2 / owner detection in loans/new + products). Set on profile creation via invite flows.
  parent_id       String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @db.Timestamptz(6)
}

model support_tickets {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id         String    @db.Uuid
  organization_id String?
  page_url        String?
  description     String
  screenshot_urls Json?     @default("[]")
  status          String?   @default("open")
  assigned_to     String?   @db.Uuid
  responses       Json?     @default("[]")
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([status], map: "idx_support_tickets_status")
  @@index([organization_id], map: "idx_support_tickets_organization_id")
  @@index([user_id], map: "idx_support_tickets_user_id")
}

model audit_logs {
  id              BigInt    @id @default(autoincrement())
  user_id         String?
  organization_id String?
  action          String
  resource_type   String
  resource_id     String?
  details         Json?     @default("{}")
  ip_address      String?
  user_agent      String?
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "idx_audit_logs_user")
  @@index([organization_id], map: "idx_audit_logs_org")
  @@index([action], map: "idx_audit_logs_action")
  @@index([resource_type], map: "idx_audit_logs_resource_type")
  @@index([created_at], map: "idx_audit_logs_created")
}

model loan_billing_events {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  loan_id         BigInt?
  organization_id String?
  tenant_name     String?
  closed_at       DateTime? @default(now()) @db.Timestamptz(6)
  loan_amount     Decimal?  @db.Decimal(12, 2)
  billed          Boolean?  @default(false)
  bill_run_date   DateTime? @db.Date
  created_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([organization_id], map: "idx_loan_billing_org")
  @@index([billed], map: "idx_loan_billing_billed")
}

model Borrower {
  id          String    @id
  profileId   String    @unique @db.Uuid
  firstName   String?
  lastName    String?
  dateOfBirth DateTime?
  ssnLast4    String?
  address     String?
  city        String?
  state       String?
  zip         String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
}

model Company {
  id             String    @id
  name           String
  ein            String?
  address        String?
  city           String?
  state          String?
  zip            String?
  status         String    @default("pending")
  cogsIssueDate  DateTime?
  cogsExpiryDate DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime
}

model CompanyBorrower {
  id         String @id
  companyId  String
  borrowerId String

  @@unique([companyId, borrowerId])
}

model CompanyOwner {
  id         String  @id
  companyId  String
  name       String
  percentage Decimal @db.Decimal(5, 2)
  isPrimary  Boolean @default(false)

  @@unique([companyId, name])
}

model Document {
  id         String    @id
  borrowerId String?
  companyId  String?
  loanId     String?
  docType    String
  fileName   String
  fileUrl    String
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
}

model LoanApplication {
  id              String   @id
  borrowerId      String
  companyId       String?
  originatorId    String   @db.Uuid
  propertyAddress String?
  propertyCity    String?
  propertyState   String?
  propertyZip     String?
  loanType        String
  loanAmount      Decimal?
  status          String   @default("draft")
  copiedFromId    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime
}

model adjustment_keys {
  id              BigInt    @id @default(autoincrement())
  organization_id String
  adjustment_type String
  canonical_key   String
  display_name    String?
  aliases         String[]
  ltv_50          Decimal?  @db.Decimal(12, 4)
  ltv_50_55       Decimal?  @db.Decimal(12, 4)
  ltv_55_60       Decimal?  @db.Decimal(12, 4)
  ltv_60_65       Decimal?  @db.Decimal(12, 4)
  ltv_65_70       Decimal?  @db.Decimal(12, 4)
  ltv_70_75       Decimal?  @db.Decimal(12, 4)
  ltv_75_80       Decimal?  @db.Decimal(12, 4)
  active          Boolean?  @default(true)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([canonical_key])
  @@index([organization_id, adjustment_type])
}

model pending_brokers {
  id                      BigInt    @id @default(autoincrement())
  full_name               String?
  email                   String?
  phone                   String?
  broker_company_name     String?
  experience_years        Int?
  monthly_volume_estimate String?
  target_organization_id  String?
  notes                   String?
  status                  String?   @default("pending")
  reviewed_by             String?
  reviewed_at             DateTime? @db.Timestamptz(6)
  created_at              DateTime? @default(now()) @db.Timestamptz(6)
  updated_at              DateTime? @default(now()) @db.Timestamptz(6)
}

model pricing_markups {
  id              String   @id
  organization_id String
  broker_id       String?  @db.Uuid
  markup_type     String
  value           Decimal  @db.Decimal(5, 3)
  description     String?
  active          Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @db.Timestamptz(6)

  @@index([markup_type])
  @@index([organization_id, broker_id, markup_type])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  ORG_ADMIN
  LOAN_UNDERWRITER
  LOAN_PROCESSOR
  SENIOR_ACCOUNT_EXECUTIVE
  ACCOUNT_EXECUTIVE
  SENIOR_BROKER
  JUNIOR_BROKER
  LENDING_SUPERVISOR
  BROKER
  BROKER_AE
  BORROWER
  TECH_SUPPORT
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations.
model documents {
  id                BigInt    @id @default(autoincrement())
  loan_id           BigInt
  doc_type          String
  file_name         String?
  file_url          String?
  status            String?   @default("NEEDED")
  xai_feedback      String?
  underwriter_notes String?
  ae_comments       Json?     @default("[]")
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  loans             loans     @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([loan_id], map: "idx_documents_loan")
  @@index([doc_type], map: "idx_documents_type")
}

model loan_applications {
  id                  String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id             String
  status              String?        @default("draft")
  form_data           Json?
  borrowers           Json?
  selected_product_id BigInt?
  pricing_result      Json?
  created_at          DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?      @default(now()) @db.Timestamptz(6)
  organization_id     String?
  organizations       organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([organization_id], map: "idx_loan_applications_org")
  @@index([status], map: "idx_loan_applications_status")
  @@index([user_id], map: "idx_loan_applications_user_id")
}

model loan_documents {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  loan_id       BigInt?
  file_name     String
  file_url      String
  document_type String?   @default("unlabeled")
  uploaded_via  String?   @default("email")
  uploaded_at   DateTime? @default(now()) @db.Timestamp(6)
  loans         loans?    @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model loan_email_logs {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  loan_id          BigInt?
  from_email       String?
  subject          String?
  analysis_summary String?
  processed_at     DateTime? @default(now()) @db.Timestamp(6)
  loans            loans?    @relation(fields: [loan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model loan_products {
  id                     String         @id @default(dbgenerated("('prod_'::text || substr(md5((random())::text), 1, 8))"))
  name                   String
  description            String?
  guidelines_url         String?
  created_at             DateTime?      @default(now()) @db.Timestamptz(6)
  pricing_matrix         Json?          @default("{\"series\": {\"standard\": {\"maxLTV\": 75, \"baseAdjustment\": 0}, \"signature\": {\"maxLTV\": 80, \"baseAdjustment\": -0.25}, \"streamline\": {\"maxLTV\": 80, \"baseAdjustment\": -0.5}}, \"baseRate\": 9.0, \"ltvAdjustments\": {\"60\": 0, \"65\": -0.125, \"70\": -0.375, \"75\": -0.75, \"80\": -1.25}, \"dscrAdjustments\": {\"1.25+\": 0, \"0.75-0.99\": -0.75, \"1.00-1.14\": -0.375, \"1.15-1.24\": -0.125}, \"ficoAdjustments\": {\"780+\": 0, \"660-679\": -2.0, \"680-699\": -1.25, \"700-719\": -0.75, \"720-739\": -0.375, \"740-759\": -0.25, \"760-779\": -0.125}}")
  active                 Boolean?       @default(true)
  organization_id        String?
  default_profit_percent Decimal?       @default(1.0) @db.Decimal
  organizations          organizations? @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([active], map: "idx_loan_products_active")
  @@index([organization_id], map: "idx_loan_products_org")
}

model loans {
  id               BigInt            @id @default(autoincrement())
  product_id       String?
  originator_id    String
  borrower_name    String?
  property_address String
  loan_amount      Decimal?          @db.Decimal(12, 2)
  loan_type        String?           @default("purchase")
  status           String?           @default("PENDING")
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?         @default(now()) @db.Timestamptz(6)
  loan_status      String?           @default("Processing")
  notes            String?
  purpose          String?
  property_type    String?
  amortization     String?

  // === NEW FIELDS FOR PERMISSIONS & WHITE-LABEL ===
  processor_id     String?
  underwriter_id   String?
  organization_id  String?

  documents        documents[]
  loan_documents   loan_documents[]
  loan_email_logs  loan_email_logs[]

  @@index([originator_id], map: "idx_loans_originator")
  @@index([product_id], map: "idx_loans_product")
  @@index([organization_id])
}

model organizations {
  id                String              @id @default(dbgenerated("('org_'::text || substr(md5((random())::text), 1, 12))"))
  name              String
  slug              String              @unique
  logo_url          String?
  primary_color     String?             @default("#000000")
  domain            String?             @unique
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  active            Boolean?            @default(true)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  clerk_org_id      String?             @unique

  // === NEW: Dual Markup Support ===
  wholesale_markup  Decimal?            @default(0) @db.Decimal(5, 2)  // for brokers
  retail_markup     Decimal?            @default(0) @db.Decimal(5, 2)  // for borrowers

  loan_applications loan_applications[]
  loan_products     loan_products[]
}

model pending_organizations {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_name         String
  contact_name         String?
  email                String    @unique
  phone                String?
  website              String?
  loan_volume_estimate String?
  notes                String?
  status               String?   @default("pending")
  reviewed_by          String?   @db.Uuid
  reviewed_at          DateTime? @db.Timestamptz(6)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
}

model profiles {
  id         String    @id
  role       String?   @default("user")
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model users {
  id              String    @id
  email           String?
  full_name       String?
  role            String?   @default("BROKER_AE")
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
  parent_id       String?
  organization_id String?     // ← NEW

  users           users?    @relation("usersTousers", fields: [parent_id], references: [id])
  other_users     users[]   @relation("usersTousers")

  @@index([role], map: "idx_users_role")
}

// ==================== NEW ENUM FOR PERMISSIONS ====================
enum Role {
  SUPER_ADMIN
  ADMIN
  LOAN_UNDERWRITER
  LOAN_PROCESSOR
  SENIOR_ACCOUNT_EXECUTIVE
  ACCOUNT_EXECUTIVE
  SENIOR_BROKER
  JUNIOR_BROKER
  LENDING_SUPERVISOR
  BROKER
  BROKER_AE
  BORROWER          // ← NEW ROLE
}